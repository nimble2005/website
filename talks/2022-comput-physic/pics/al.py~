def epspl(dist, ep, phi, plo):
    step = np.float64(1e-3)
    intep = splrep(dist, ep)
    distleft = plo
    distright = phi
    num = np.int64(np.ceil((distright-distleft)/step))+1
    xdis = np.linspace(distleft, distright, num, endpoint=True)
    intvp = splev(xdis, intep, der=0)
    return xdis, intvp, step, num


