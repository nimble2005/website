def data_gen():
    dir_data = "/home/nby/study/vanadium-new/SUST/BCC/curvedata/"
    file_ep = dir_data + "energy_sv_" + "1.00_mag.dat"
    ep = np.loadtxt(file_ep)
    ep0 = ep[0]
    ep = ep - ep0
    dis = np.linspace(0, 0.5, 11)
    return dis, ep


def plot_frame(data):
