<section id="slide-org5e722c2">
<h2 id="org5e722c2"></h2>
<div class="ti_font" style="color: cyan">Appendix: Mathematics Proof of DIA (2D Integral)</div>
<br>
<p class="appdmath">
    \begin{eqnarray}
    &&I_{2D}=\int_0^{a_1}dx\int_0^{a_2}dye^{-U(x,y)},\\
    &&X'(x)=\int_0^xe^{-U(\xi,0)}d\xi, Y'(y)=\int_0^ye^{-U(0,\xi)}d\xi.\\
    &&X'(0)=0, Y'(0)=0\\
    &&a'_1=\int_0^{a_1}e^{-U(\xi,0)}d\xi,a'_2=\int_0^{a_2}e^{-U(0,\xi)}d\xi\\
    &&I_{2D}=\int_0^{a'_1}dX'\int_0^{a'_2}dY'e^{-F(X',Y')}.\\
    &&\text{If U(x,y) has a minimum at the origin (x=0, y=0) and U(0,0)=0},\\
    &&F(0,0)=0,\frac{\partial F}{\partial X'}{\Big |}_0=\frac{\partial F}{\partial Y'}{\Big |}_0=0\\
    &&I_{2D}\simeq a'_1a'_2.
    \end{eqnarray}
</p>

</section>
