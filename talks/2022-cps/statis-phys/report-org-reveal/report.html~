	<div class="page2_img_pic2">
	    <img src="../pics/int2d.png" height="350" width="320"/>
	    <p class="mathfont3">$$I_{2D}\rightarrow\text{Effective Area}$$</p>
	</div>
	<p class="page2_img_text ti_font1", style="color:red">
	    \begin{equation}
	    I_{ND}\longrightarrow N\text{-Dimensional  Effective  Volume}
	    \end{equation}
	</p>
    </div>
    <div class="page2_anim fragment current-visible">
	<p class="page2_anim_text page2_math">
	    \begin{eqnarray}
	    \mathcal Q&=&\int dq^{3N}\exp[-\beta U(q^{3N})], \\
	    \textcolor{red}{U'(q'^{3N})}&\textcolor{red}{=}&\textcolor{red}{U(q^{3N})-U_0},\quad \textcolor{red}{q'_i=q_i-q_0},\\
	    \mathcal{Q}&=&e^{-\beta U_0}\int dq'^{3N}\exp[-\beta U'(q'^{3N})]=e^{-\beta U_0}\mathcal{Q}'\\
	    \mathcal{Q}'&\simeq&\prod_{i=1}^{3N}\mathcal{L}_i, \\
	    \quad\mathcal{L}_i&=&\int e^{-\beta U'(0\ldots q'_i\ldots 0)}dq'_i
	    \end{eqnarray}
	    $$\Downarrow$$
	    \begin{equation}
	    {\color{red}3N\text{-Dimensional CI}\rightarrow 3N \text{ One-Dimensional Integrals}}
	    \end{equation}
	</p>
	<div class="page2_ci">
	<img src="../pics/ciphase.png" height="480" width="400"/>
	<p class="page2_math">Shrink the 3N-Dimensional effective volume</p>
	</div>
    </div>
</div>
<p class="page2_ref">
